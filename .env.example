# Azure
AZURE_STORAGE_CONNECTION_STRING=
TIMEZONE=America/New_York
SLO_MINUTES=420
JOB_SECRET=

# SMS provider selection: twilio | azure-communication | infobip (default: twilio)
SMS_PROVIDER=twilio

# Twilio (required when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ADAM_TO_NUMBER=

# Webhook security
# (Optional for now; used in later issues)
# TWILIO_WEBHOOK_URL=

# Azure Communication Services (required when SMS_PROVIDER=azure-communication)
# ACS_CONNECTION_STRING=endpoint=https://<resource>.communication.azure.com/;accesskey=<base64key>
# ACS_FROM_NUMBER=+1XXXXXXXXXX

# Infobip (required when SMS_PROVIDER=infobip)
# INFOBIP_BASE_URL=<your-base-url>.api.infobip.com
# INFOBIP_API_KEY=
# INFOBIP_FROM=+1XXXXXXXXXX
# INFOBIP_WEBHOOK_SECRET=   # optional: shared secret for inbound webhook verification
